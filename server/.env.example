PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/uniswap?retryWrites=true&w=majority
JWT_SECRET=replace_with_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
ADMIN_EMAIL=u2020001@giki.edu.pk
NODE_ENV=development

# ─── Cloudinary (image storage) ────────────────────────────────────────────
# Required in production — Render's filesystem is ephemeral, so uploads to
# `server/uploads/` are wiped on every deploy.
#
# Either set the single shortcut URL (preferred):
#   CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
#
# …OR set the three discrete vars:
#   CLOUDINARY_CLOUD_NAME=
#   CLOUDINARY_API_KEY=
#   CLOUDINARY_API_SECRET=
#
# Leave them blank locally and the app falls back to local disk storage.
